# See http://help.github.com/ignore-files/ for more about ignoring files.

# Build outputs
/dist
/tmp
/out-tsc
/bazel-out
.angular/
*.tsbuildinfo

# Node
/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.pnpm-store
.pnp.*
.yarn/

# Environment / secrets — never commit any of these
.env
.env.*
!.env.example
*.pem
*.key
*.p12
.npmrc
.netrc

# Coverage and test output
/coverage
.nyc_output
testem.log
/libpeerconnection.log

# IDE / editor
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.sublime-project
.history/

# VS Code: ignore everything except shared, project-level config
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
!.vscode/tasks.json

# Lighthouse CI
.lighthouseci

# Playwright (MCP scratch dir + default report locations)
.playwright-mcp/
playwright-report/
test-results/

# AI / agent tooling — kept out of public repo
.claude/
.cursor/
.aider*
.continue/

# OS
.DS_Store
**/.DS_Store
Thumbs.db

# Misc
.sass-cache/
/connect.lock
/typings
*.log
